---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Search"
  description="Search across all OmniSet content — tools, distros, guides, docs, glossary, and more."
  canonical="https://omniset.org/search/"
  noindex={true}
>
  <section class="py-20 bg-gradient-hero text-white">
    <div class="container mx-auto px-6">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">Search</h1>
        <div class="relative max-w-xl mx-auto">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <input
            type="search"
            id="search-input"
            placeholder="Search tools, distros, guides..."
            autofocus
            class="w-full pl-12 pr-4 py-4 rounded-xl text-gray-900 text-lg bg-white shadow-xl focus:outline-none focus:ring-2 focus:ring-orange-400"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        <div id="search-status" class="text-gray-500 mb-6 hidden"></div>
        <div id="search-results" class="space-y-4"></div>
        <div id="search-empty" class="text-center py-12 hidden">
          <p class="text-gray-500 text-lg">No results found. Try a different search term.</p>
        </div>
        <div id="search-initial" class="text-center py-12">
          <p class="text-gray-400 text-lg">Start typing to search across all content</p>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (function() {
      let index = null;
      const input = document.getElementById('search-input');
      const results = document.getElementById('search-results');
      const status = document.getElementById('search-status');
      const empty = document.getElementById('search-empty');
      const initial = document.getElementById('search-initial');

      const typeColors = {
        'Tool': 'bg-blue-100 text-blue-700',
        'Distro': 'bg-green-100 text-green-700',
        'Guide': 'bg-purple-100 text-purple-700',
        'Docs': 'bg-gray-100 text-gray-700',
        'Glossary': 'bg-yellow-100 text-yellow-700',
        'Comparison': 'bg-orange-100 text-orange-700',
        'Alternative': 'bg-red-100 text-red-700',
        'Use Case': 'bg-teal-100 text-teal-700',
        'Blog': 'bg-pink-100 text-pink-700'
      };

      async function loadIndex() {
        if (index) return;
        const res = await fetch('/search-index.json');
        index = await res.json();
      }

      function search(query) {
        if (!index || !query.trim()) {
          results.innerHTML = '';
          status.classList.add('hidden');
          empty.classList.add('hidden');
          initial.classList.toggle('hidden', query.trim().length > 0);
          return;
        }

        initial.classList.add('hidden');
        const q = query.toLowerCase();
        const matches = index.filter(item =>
          item.title.toLowerCase().includes(q) ||
          item.description.toLowerCase().includes(q)
        );

        status.textContent = `${matches.length} result${matches.length !== 1 ? 's' : ''} for "${query}"`;
        status.classList.remove('hidden');
        empty.classList.toggle('hidden', matches.length > 0);

        results.innerHTML = matches.map(item => `
          <a href="${item.url}" class="block p-5 rounded-xl border border-gray-200 hover:shadow-md hover:border-orange-200 transition-all">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-xs px-2 py-0.5 rounded-full font-medium ${typeColors[item.type] || 'bg-gray-100 text-gray-700'}">${item.type}</span>
              <h3 class="font-semibold text-gray-900">${item.title}</h3>
            </div>
            <p class="text-sm text-gray-600">${item.description}</p>
          </a>
        `).join('');
      }

      // Load index on first interaction
      input.addEventListener('focus', loadIndex, { once: true });

      // Debounced search
      let timer;
      input.addEventListener('input', () => {
        clearTimeout(timer);
        timer = setTimeout(() => search(input.value), 150);
      });

      // Support ?q= URL parameter
      const params = new URLSearchParams(window.location.search);
      const q = params.get('q');
      if (q) {
        input.value = q;
        loadIndex().then(() => search(q));
      }
    })();
  </script>
</BaseLayout>
