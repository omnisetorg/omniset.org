---
// Navigation Header component
---

<header role="banner" class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-200">
  <div class="container mx-auto px-6">
    <nav role="navigation" aria-label="Main navigation" class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2 text-xl font-bold text-gray-900" aria-label="OmniSet - Home">
        <img src="/logo.svg" alt="" class="w-8 h-8" aria-hidden="true" />
        OmniSet
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="/docs/" class="text-gray-600 hover:text-gray-900 transition-colors">Docs</a>
        <a href="/guides/" class="text-gray-600 hover:text-gray-900 transition-colors">Guides</a>
        <a href="/blog/" class="text-gray-600 hover:text-gray-900 transition-colors">Blog</a>
        <a href="https://github.com/omnisetorg" target="_blank" rel="noopener noreferrer" class="text-gray-600 hover:text-gray-900 transition-colors">GitHub</a>
        <a href="/search/" class="text-gray-600 hover:text-gray-900 transition-colors" aria-label="Search">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </a>
        <a href="/#get-started" class="px-5 py-2 bg-orange-600 text-white rounded-lg hover:bg-orange-700 transition-all hover:-translate-y-0.5">Get Started</a>
      </div>
      <button class="md:hidden p-2" id="mobile-menu-btn" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round"/>
        </svg>
      </button>
    </nav>
    <!-- Mobile menu -->
    <div class="hidden md:hidden pb-4" id="mobile-menu" role="menu" aria-label="Mobile navigation">
      <a href="/docs/" role="menuitem" class="block py-2 text-gray-600 hover:text-gray-900">Docs</a>
      <a href="/guides/" role="menuitem" class="block py-2 text-gray-600 hover:text-gray-900">Guides</a>
      <a href="/blog/" role="menuitem" class="block py-2 text-gray-600 hover:text-gray-900">Blog</a>
      <a href="https://github.com/omnisetorg" target="_blank" rel="noopener noreferrer" role="menuitem" class="block py-2 text-gray-600 hover:text-gray-900">GitHub</a>
      <a href="/search/" role="menuitem" class="block py-2 text-gray-600 hover:text-gray-900">Search</a>
      <a href="/#get-started" role="menuitem" class="block py-2 text-orange-600 font-medium">Get Started</a>
    </div>
  </div>
</header>
