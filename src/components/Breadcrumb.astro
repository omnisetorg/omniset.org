---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-4">
  <ol class="flex items-center gap-2 text-sm text-white/70">
    {items.map((item, index) => (
      <li class="flex items-center gap-2">
        {index > 0 && (
          <svg class="w-4 h-4 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        )}
        {item.href ? (
          <a href={item.href} class="hover:text-white transition-colors">{item.label}</a>
        ) : (
          <span class="text-white/90">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
