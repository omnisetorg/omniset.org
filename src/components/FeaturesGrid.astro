---
// Features grid section
const features = [
  {
    title: 'Private by default',
    description: 'Linux doesn\'t track you, serve you ads, or bundle software you didn\'t ask for. Your machine, your rules.',
    icon: 'shield',
    bgColor: 'bg-green-100',
    strokeColor: '#16a34a'
  },
  {
    title: 'Premium feel, zero cost',
    description: 'Get a polished desktop experience on any hardware you already own — no $2,000 laptop required.',
    icon: 'dollar',
    bgColor: 'bg-amber-100',
    strokeColor: '#d97706'
  },
  {
    title: 'Built to be yours',
    description: 'Swap desktops, tweak workflows, automate anything. Linux adapts to how you work, not the other way around.',
    icon: 'cog',
    bgColor: 'bg-purple-100',
    strokeColor: '#9333ea'
  },
  {
    title: 'Quiet updates',
    description: 'Updates happen in the background and apply when you\'re ready. No forced restarts, no surprise reboots.',
    icon: 'refresh',
    bgColor: 'bg-blue-100',
    strokeColor: '#2563eb'
  },
  {
    title: 'Open source, always',
    description: 'Every line of OmniSet is public. Read it, fork it, improve it — this project belongs to its community.',
    icon: 'users',
    bgColor: 'bg-pink-100',
    strokeColor: '#db2777'
  },
  {
    title: 'Runs on anything',
    description: 'That old laptop collecting dust? Linux can bring it back. Works on Intel, AMD, ARM — new or decade-old.',
    icon: 'chip',
    bgColor: 'bg-orange-100',
    strokeColor: '#ea580c'
  }
];

const iconPaths: Record<string, string> = {
  shield: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  dollar: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  cog: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z',
  refresh: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
  users: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
  chip: 'M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z'
};
---

<section class="py-20 bg-white">
  <div class="container mx-auto px-6">
    <div class="text-center mb-16 reveal">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 text-gray-900">Why people make the switch</h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Real reasons, not marketing fluff.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-5xl mx-auto">
      {features.map((feature, i) => (
        <div class="p-6 rounded-2xl bg-gray-50 hover:bg-gray-100 transition-colors reveal" style={`transition-delay: ${i * 100}ms`}>
          <div class={`w-12 h-12 ${feature.bgColor} rounded-xl flex items-center justify-center mb-4`}>
            <svg width="24" height="24" fill="none" stroke={feature.strokeColor} stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path d={iconPaths[feature.icon]} stroke-linecap="round" stroke-linejoin="round"/>
              {feature.icon === 'cog' && (
                <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round"/>
              )}
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2 text-gray-900">{feature.title}</h3>
          <p class="text-gray-600 text-sm leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
