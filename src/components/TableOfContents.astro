---
interface TocItem {
  title: string;
  id: string;
}

interface Props {
  items: TocItem[];
  label?: string;
}

const { items, label = 'On this page' } = Astro.props;
---

<!-- Desktop: sticky sidebar -->
<div class="hidden lg:block">
  <div class="sticky top-24">
    <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wide mb-4">{label}</h3>
    <nav class="space-y-2">
      {items.map((item) => (
        <a
          href={`#${item.id}`}
          class="block text-sm text-gray-600 hover:text-orange-600 transition-colors"
        >
          {item.title}
        </a>
      ))}
    </nav>
    <slot />
  </div>
</div>

<!-- Mobile: collapsible -->
<details class="lg:hidden mb-8 bg-gray-50 rounded-xl p-4">
  <summary class="font-semibold text-gray-900 cursor-pointer">{label}</summary>
  <nav class="mt-3 space-y-2">
    {items.map((item) => (
      <a
        href={`#${item.id}`}
        class="block text-sm text-gray-600 hover:text-orange-600 transition-colors py-1"
      >
        {item.title}
      </a>
    ))}
  </nav>
</details>
